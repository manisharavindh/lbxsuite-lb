# ===== LbxSuite Admin Portal — Environment Variables =====

# Supabase Connection
SUPABASE_URL=SUPABASE_URL_HERE
SUPABASE_KEY=SUPABASE_ANON_KEY_HERE

# Admin Credentials
ADMIN_USERNAME=USERNAME_PLACEHOLDER
ADMIN_PASSWORD=ADMIN_PASSWORD_PLACEHOLDER

# JWT Secret
JWT_SECRET=JWT_SECRET_PLACEHOLDER

# Resend
RESEND_API_KEY="re_..."
RESEND_AUDIENCE_ID="..."

# Server Port
PORT=

# Node Environment
NODE_ENV=production
