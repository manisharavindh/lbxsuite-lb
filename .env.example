# ===== LbxSuite Admin Portal — Environment Variables =====

# Supabase Connection
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Admin Credentials
ADMIN_USERNAME=YOUR_ADMIN_USERNAME_PLACEHOLDER
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_PLACEHOLDER

# JWT Secret
JWT_SECRET=YOUR_JWT_SECRET_PLACEHOLDER

# Server Port
PORT=

# Node Environment
NODE_ENV=production
